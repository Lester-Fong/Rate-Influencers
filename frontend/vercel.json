{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://rate-influencers-api.onrender.com/api/:path*"
    },
    {
      "source": "/sanctum/:path*",
      "destination": "https://rate-influencers-api.onrender.com/sanctum/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
